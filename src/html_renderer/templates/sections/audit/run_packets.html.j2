<section id="run_wise_evidence_packets">{{ page.section_heading_html }}{% for packet in page.packets %}<article class="run-packet" id="packet-{{ packet.run_id_html }}"><header><div><div class="packet-label">Run-wise evidence packet</div><h3>{{ packet.run_label_html }}</h3></div><div>{% for badge in packet.badges %}<span class="status-badge status-{{ badge.status_class }}">{{ badge.label_html }}</span>{% if not loop.last %} {% endif %}{% endfor %}</div></header><div class="run-packet-body">{% for block_html in packet.blocks_html %}{{ block_html }}{% endfor %}</div></article>{% endfor %}</section>
