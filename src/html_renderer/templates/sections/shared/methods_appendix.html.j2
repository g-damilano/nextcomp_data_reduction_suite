<section class="methods-appendix" aria-hidden="true"><h2>{{ page.heading_html }}</h2><p class="appendix-lede">{{ page.lede_html }}</p>{% for item in page.items %}<div class="appendix-item"><h3>A.{{ loop.index }} {{ item.title_html }} <span class="ref">({{ item.label_html }})</span></h3>{% for paragraph in item.paragraphs %}<p>{{ paragraph.html }}</p>{% endfor %}</div>{% endfor %}</section>
