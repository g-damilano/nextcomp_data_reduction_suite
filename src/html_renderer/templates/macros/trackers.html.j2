{% macro formal_report_tracker(links) -%}<nav aria-label="Report sections" class="report-tracker">{% for link in links %}<a href="#section-{{ link.section_id_html }}"><b>{{ link.number }}</b><span>{{ link.title_html }}</span>{{ link.pill_html }}</a>{% endfor %}</nav>{%- endmacro %}
{% macro audit_report_tracker(links) -%}<nav aria-label="Audit report locations" class="report-tracker">{% for link in links %}<a href="#{{ link.anchor_html }}"><b>{{ link.number_html }}</b><span>{{ link.label_html }}</span>{{ link.pill_html }}</a>{% if link.run_links %}<div class="report-tracker-sublist">{% for run_link in link.run_links %}<a href="#packet-{{ run_link.anchor_html }}"><b>{{ run_link.number }}</b><span>{{ run_link.label_html }}</span></a>{% endfor %}</div>{% endif %}{% endfor %}</nav>{%- endmacro %}
